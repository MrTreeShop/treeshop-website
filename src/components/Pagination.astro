---
interface Props {
  currentPage: number;
  lastPage: number;
  baseUrl: string;
}

const { currentPage, lastPage, baseUrl } = Astro.props;
const prevUrl = currentPage > 1 ? (currentPage === 2 ? baseUrl : `${baseUrl}${currentPage - 1}/`) : null;
const nextUrl = currentPage < lastPage ? `${baseUrl}${currentPage + 1}/` : null;
---

{lastPage > 1 && (
  <nav class="flex items-center justify-center gap-4 pt-12" aria-label="Pagination">
    {prevUrl ? (
      <a href={prevUrl} class="inline-flex items-center gap-2 bg-dark-700 border border-white/5 text-gray-300 hover:text-white hover:border-primary-500/30 font-semibold px-5 py-2.5 rounded-xl transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Previous
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 bg-dark-700/50 text-gray-600 font-semibold px-5 py-2.5 rounded-xl cursor-not-allowed">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
        Previous
      </span>
    )}

    <span class="text-sm text-gray-400">
      Page {currentPage} of {lastPage}
    </span>

    {nextUrl ? (
      <a href={nextUrl} class="inline-flex items-center gap-2 bg-dark-700 border border-white/5 text-gray-300 hover:text-white hover:border-primary-500/30 font-semibold px-5 py-2.5 rounded-xl transition-colors">
        Next
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
    ) : (
      <span class="inline-flex items-center gap-2 bg-dark-700/50 text-gray-600 font-semibold px-5 py-2.5 rounded-xl cursor-not-allowed">
        Next
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </span>
    )}
  </nav>
)}
