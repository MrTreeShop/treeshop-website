---
interface Props {
  serviceName?: string;
  serviceSlug?: string;
}

const { serviceName = 'Forestry Mulching', serviceSlug = 'forestry-mulching' } = Astro.props;
const phone = "(386) 843-5266";
const phoneHref = "tel:+13868435266";
---

<aside class="bg-dark-700 border border-primary-500/20 rounded-xl p-6 my-8 not-prose">
  <h3 class="text-lg font-bold text-white mb-2">Ready to Get Started?</h3>
  <p class="text-sm text-gray-400 mb-4">TreeShop provides professional {serviceName.toLowerCase()} across Central Florida. 500+ projects completed, CAT equipment, owner-operated.</p>
  <div class="flex flex-col sm:flex-row gap-3">
    <a href={`/services/${serviceSlug}/#contact`} class="inline-flex items-center justify-center bg-primary-500 hover:bg-primary-600 text-white font-bold text-sm px-5 py-2.5 rounded-xl transition-colors">
      Get Free Estimate
    </a>
    <a href={phoneHref} class="inline-flex items-center justify-center bg-white/10 hover:bg-white/15 text-white font-semibold text-sm px-5 py-2.5 rounded-xl border border-white/10 transition-colors">
      Call {phone}
    </a>
  </div>
</aside>
