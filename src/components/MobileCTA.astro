---
import { company } from '../data/company';

interface Props {
  ctaHref?: string;
  ctaLabel?: string;
}

const { ctaHref = '#contact', ctaLabel = 'Get Started' } = Astro.props;
---

<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-dark-900/95 backdrop-blur-md border-t border-white/10 p-3">
  <div class="flex gap-2">
    <a href={company.phoneHref} class="flex-1 flex items-center justify-center gap-2 bg-white/10 text-white font-semibold py-3 rounded-xl">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
      Call
    </a>
    <a href={ctaHref} class="flex-1 flex items-center justify-center gap-2 bg-primary-500 text-white font-semibold py-3 rounded-xl">
      {ctaLabel}
    </a>
  </div>
</div>
