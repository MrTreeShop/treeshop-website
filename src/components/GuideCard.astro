---
interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;
---

<a href={`/learn/${slug}/`} class="block bg-dark-800 border border-white/5 rounded-xl p-6 hover:border-green-500/30 hover:bg-dark-700 transition-all group">
  <div class="flex items-center gap-2 mb-3">
    <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
    <span class="text-xs font-semibold text-green-400 uppercase tracking-wider">Guide</span>
  </div>
  <h3 class="text-lg font-bold text-white group-hover:text-green-400 transition-colors mb-2">{title}</h3>
  <p class="text-sm text-gray-400 line-clamp-3">{description}</p>
</a>
