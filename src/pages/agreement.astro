---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.png';

const phone = "(386) 843-5266";
const phoneHref = "tel:+13868435266";
const docHubUrl = "https://dochub.com/m/shared-document/office-e99l1c/oGZeMNnwXg8k72kVQvbrYd/treeshop-msa-2026-4-pdf?dt=dS2zFGhyLBX8UVzKvfud";

const faqs = [
  {
    q: "What does this agreement cover?",
    a: "Scope of work, scheduling, payment terms, liability, and cancellation policy. It's the standard framework that applies to all TreeShop services."
  },
  {
    q: "Do I need to sign before getting a quote?",
    a: "No. You'll receive a separate work order or quote for your specific project. This agreement covers the general terms for all TreeShop services."
  },
  {
    q: "What happens after I sign?",
    a: "You'll receive a signed copy via email. We'll then schedule a site visit if needed, send your project quote, and get your work on the calendar."
  },
  {
    q: "Can I ask questions before signing?",
    a: "Of course. Call us at (386) 843-5266 or email office@treeshop.app — we're happy to walk through anything."
  }
];
---

<Layout
  title="Service Agreement | TreeShop LLC"
  description="Review and sign TreeShop's Master Service Agreement. Covers scope, scheduling, and payment terms for forestry mulching and land clearing services across Central Florida."
>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-dark-900/90 backdrop-blur-md border-b border-white/5">
    <div class="max-w-7xl mx-auto fluid-px">
      <div class="flex items-center justify-between h-16 sm:h-20">
        <a href="/" class="flex items-center">
          <Image src={logo} alt="TreeShop LLC" width={40} height={40} class="rounded-lg" />
        </a>
        <div class="flex items-center gap-3">
          <a href={phoneHref} class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            {phone}
          </a>
          <a href="/" class="text-sm text-gray-400 hover:text-white transition-colors">Back to Home</a>
        </div>
      </div>
    </div>
  </nav>

  <main class="pt-24 sm:pt-32">
    <!-- Hero Section -->
    <section class="fluid-section">
      <div class="max-w-3xl mx-auto fluid-px text-center">
        <div class="inline-flex items-center gap-2 bg-primary-500/10 border border-primary-500/20 rounded-full px-4 py-1.5 mb-6">
          <svg class="w-4 h-4 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          <span class="text-sm text-primary-400 font-medium">Takes about 2 minutes</span>
        </div>

        <h1 class="fluid-hero font-bold text-white mb-6">Service Agreement</h1>
        <p class="fluid-sub text-gray-400 leading-relaxed mb-10 max-w-2xl mx-auto">
          This is TreeShop's standard service agreement covering scope, scheduling, and payment terms. Signing this is the step that gets your project on the calendar.
        </p>

        <a
          href={docHubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-primary-500 hover:bg-primary-600 text-white text-lg font-semibold px-8 py-4 rounded-xl transition-colors"
        >
          Review & Sign Agreement
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
        </a>

        <p class="text-sm text-gray-400 mt-4">Opens in DocHub. A signed copy is emailed to both parties.</p>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="border-t border-white/5 py-12">
      <div class="max-w-3xl mx-auto fluid-px">
        <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-400">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
            <span>Fully Licensed & Insured</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path></svg>
            <span>4.8 Stars / 97 Reviews</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <span>500+ Projects Completed</span>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="fluid-section border-t border-white/5">
      <div class="max-w-3xl mx-auto fluid-px">
        <h2 class="fluid-h2 font-bold text-white text-center mb-12">Common Questions</h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <div class="bg-dark-800 border border-white/5 rounded-xl p-6">
              <h3 class="font-semibold text-white mb-2">{faq.q}</h3>
              <p class="text-gray-400 leading-relaxed">{faq.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="fluid-section border-t border-white/5">
      <div class="max-w-3xl mx-auto fluid-px text-center">
        <h2 class="fluid-h2 font-bold text-white mb-4">Ready to get started?</h2>
        <p class="text-gray-400 mb-8">Sign the agreement and we'll get your project on the calendar.</p>
        <a
          href={docHubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-primary-500 hover:bg-primary-600 text-white text-lg font-semibold px-8 py-4 rounded-xl transition-colors"
        >
          Review & Sign Agreement
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
        </a>
        <p class="text-sm text-gray-400 mt-6">Questions? Call <a href={phoneHref} class="text-primary-400 hover:text-primary-300">{phone}</a> or email <a href="mailto:office@treeshop.app" class="text-primary-400 hover:text-primary-300">office@treeshop.app</a></p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/5 py-12">
    <div class="max-w-7xl mx-auto fluid-px">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <Image src={logo} alt="TreeShop LLC" width={28} height={28} class="rounded-lg" />
          <p class="text-sm text-gray-400">&copy; {new Date().getFullYear()} TreeShop LLC. All rights reserved.</p>
        </div>
        <div class="flex gap-6">
          <a href="/" class="text-sm text-gray-500 hover:text-gray-400 transition-colors">Home</a>
          <a href="/privacy/" class="text-sm text-gray-500 hover:text-gray-400 transition-colors">Privacy</a>
          <a href="/terms/" class="text-sm text-gray-500 hover:text-gray-400 transition-colors">Terms</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>
