---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Sidebar from '../../components/Sidebar.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { company } from '../../data/company';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const guides = await getCollection('guides', ({ data }) => !data.draft);
  return guides.map((guide) => ({
    params: { slug: guide.id.replace(/\.mdx?$/, '') },
    props: { guide },
  }));
}) satisfies GetStaticPaths;

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

// Estimate reading time
const wordCount = guide.body ? guide.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const formattedDate = guide.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${guide.data.title} | TreeShop LLC`} description={guide.data.description} ogImage="/og-guides.jpg">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": guide.data.title,
    "description": guide.data.description,
    "datePublished": guide.data.pubDate.toISOString(),
    "author": {
      "@type": "Organization",
      "name": "TreeShop LLC",
      "url": "https://treeshop.app"
    },
    "publisher": {
      "@type": "Organization",
      "name": "TreeShop LLC",
      "url": "https://treeshop.app",
      "logo": {
        "@type": "ImageObject",
        "url": "https://treeshop.app/favicon.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://treeshop.app/learn/${guide.id.replace(/\.mdx?$/, '')}/`
    },
    "wordCount": wordCount,
    "image": "https://treeshop.app/og-image.jpg"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://treeshop.app/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Learn",
        "item": "https://treeshop.app/learn/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": guide.data.title
      }
    ]
  })} />
  <Nav mode="subpage" ctaHref="#contact" />

  <div class="pt-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: 'Learn', href: '/learn/' },
        { label: guide.data.title }
      ]} />
    </div>
  </div>

  <!-- Guide Header -->
  <header class="bg-dark-900 pb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-flex items-center gap-1.5 bg-green-500/10 text-green-400 text-xs font-semibold px-3 py-1 rounded-full border border-green-500/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            Guide
          </span>
          <span class="text-sm text-gray-500">{formattedDate}</span>
          <span class="text-sm text-gray-500">&middot; {readingTime} min read</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight">
          {guide.data.title}
        </h1>
        <p class="mt-4 text-lg text-gray-400">{guide.data.description}</p>
      </div>
    </div>
  </header>

  <!-- Guide Body -->
  <section class="py-12 sm:py-16 bg-dark-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <article class="lg:col-span-2 prose">
          <Content />
        </article>
        <aside class="space-y-6">
          {guide.data.tableOfContents && headings.length > 0 && (
            <TableOfContents headings={headings} />
          )}
          <Sidebar serviceName="Forestry Mulching" activeSlug="forestry-mulching" />
        </aside>
      </div>
    </div>
  </section>

  <Footer padBottom={true} />
  <MobileCTA />
</Layout>
