---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import ContactSection from '../../components/ContactSection.astro';
import { company } from '../../data/company';

const pageTitle = "Annual Land Management Partnerships | TreeShop LLC | Central Florida";
const pageDesc = "Year-round land management partnerships for 100+ acre landowners across Central Florida. Scheduled maintenance, monitoring, and adaptive management. Call (386) 843-5266.";
---

<Layout title={pageTitle} description={pageDesc}>
  <Nav mode="subpage" ctaHref="#contact" />

  <!-- HERO -->
  <section class="pt-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-gray-500 pt-8 sm:pt-12 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/#services" class="hover:text-white transition-colors">Services</a>
        <span>/</span>
        <span class="text-gray-300">Annual Partnerships</span>
      </nav>

      <div class="max-w-3xl pb-16 sm:pb-20">
        <div class="inline-flex items-center gap-2 bg-primary-500/10 border border-primary-500/20 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
          <span class="text-sm text-primary-400">Year-Round Management</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.1] mb-6">
          Annual Land Management Partnerships
        </h1>

        <p class="text-lg text-gray-400 mb-8 max-w-2xl">
          For landowners who want consistent, year-round management — not one-off projects. TreeShop annual partnerships provide scheduled maintenance, monitoring, and adaptive management across your entire property.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="inline-flex items-center justify-center bg-primary-500 hover:bg-primary-600 text-white font-bold text-lg px-8 py-4 rounded-xl transition-colors">
            Schedule a Land Assessment
          </a>
          <a href={company.phoneHref} class="inline-flex items-center justify-center bg-white/5 hover:bg-white/10 text-white font-semibold text-lg px-8 py-4 rounded-xl border border-white/10 transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            Call {company.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILS -->
  <section class="py-16 sm:py-24 bg-dark-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">What's Included</h2>
        <ul class="space-y-4">
          {[
            "Scheduled forestry mulching and regrowth control",
            "Firebreak maintenance and fuel load monitoring",
            "Invasive species monitoring and treatment",
            "Trail and access road maintenance",
            "Fence line and boundary upkeep",
            "Priority scheduling and preferred rates",
            "Annual property assessment and management plan review",
            "EQIP and cost-share program coordination",
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-gray-400">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="py-16 sm:py-24 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Who This Is For</h2>
        <p class="text-gray-400 leading-relaxed mb-6">
          Annual partnerships are designed for landowners with 100+ acres who need consistent, professional management — not periodic emergency calls when things get out of hand.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            "Timber landowners managing production stands",
            "Hunting clubs maintaining wildlife habitat",
            "Conservation landowners with EQIP contracts",
            "Absentee landowners who need reliable stewardship",
          ].map((item) => (
            <div class="bg-dark-800 border border-white/5 rounded-xl p-4">
              <p class="text-sm text-gray-300">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ContactSection heading="Schedule a Land Assessment" />

  <Footer padBottom={true} />

  <MobileCTA ctaLabel="Schedule Assessment" />
</Layout>
