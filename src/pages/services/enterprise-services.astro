---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MobileCTA from '../../components/MobileCTA.astro';
import ContactSection from '../../components/ContactSection.astro';
import { company } from '../../data/company';

const pageTitle = "Enterprise & Institutional Services | TreeShop LLC | Central Florida";
const pageDesc = "Large-scale land management for agencies, utilities, timber companies, and municipalities across Central Florida. Professional-grade CAT equipment. Call (386) 843-5266.";
---

<Layout title={pageTitle} description={pageDesc}>
  <Nav mode="subpage" ctaHref="#contact" />

  <!-- HERO -->
  <section class="pt-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-gray-500 pt-8 sm:pt-12 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/#services" class="hover:text-white transition-colors">Services</a>
        <span>/</span>
        <span class="text-gray-300">Enterprise Services</span>
      </nav>

      <div class="max-w-3xl pb-16 sm:pb-20">
        <div class="inline-flex items-center gap-2 bg-primary-500/10 border border-primary-500/20 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
          <span class="text-sm text-primary-400">Large-Scale Operations</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-[1.1] mb-6">
          Enterprise & Institutional Services
        </h1>

        <p class="text-lg text-gray-400 mb-8 max-w-2xl">
          TreeShop provides large-scale mechanical land management for organizations that need professional-grade equipment, reliable scheduling, and documented results across significant acreage.
        </p>

        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact" class="inline-flex items-center justify-center bg-primary-500 hover:bg-primary-600 text-white font-bold text-lg px-8 py-4 rounded-xl transition-colors">
            Request a Proposal
          </a>
          <a href={company.phoneHref} class="inline-flex items-center justify-center bg-white/5 hover:bg-white/10 text-white font-semibold text-lg px-8 py-4 rounded-xl border border-white/10 transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            Call {company.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="py-16 sm:py-24 bg-dark-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Capabilities</h2>
        <ul class="space-y-4">
          {[
            "Large-acreage forestry mulching and site preparation",
            "Right-of-way and utility easement clearing and maintenance",
            "Fuel load reduction and wildfire mitigation programs",
            "Timber stand improvement across production forests",
            "NRCS conservation practice implementation at scale",
            "Multi-phase project planning and execution",
            "Documentation and reporting for compliance requirements",
            "Emergency response and storm damage recovery",
          ].map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-gray-400">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="py-16 sm:py-24 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">Who This Is For</h2>
        <p class="text-gray-400 leading-relaxed mb-6">
          Enterprise services are designed for organizations managing 500+ acres or requiring institutional-grade land management with documentation, scheduling, and accountability.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            "State and federal land management agencies",
            "Utility companies and pipeline operators",
            "Timber companies and forestry investment organizations",
            "Municipalities and county governments",
            "Large-scale conservation organizations",
            "Real estate developers with multi-parcel projects",
          ].map((item) => (
            <div class="bg-dark-800 border border-white/5 rounded-xl p-4">
              <p class="text-sm text-gray-300">{item}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ContactSection heading="Request a Proposal" subtitle="Tell us about your project scope and requirements. We'll respond within 24 hours with a tailored proposal." />

  <Footer padBottom={true} />

  <MobileCTA ctaLabel="Request Proposal" />
</Layout>
