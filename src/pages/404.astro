---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found | TreeShop LLC" description="The page you're looking for doesn't exist.">
  <Nav mode="subpage" ctaHref="/" />

  <section class="pt-20 bg-dark-900 min-h-[70vh] flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24">
      <p class="text-8xl font-black text-white/10 mb-4">404</p>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">Page Not Found</h1>
      <p class="text-lg text-gray-400 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center justify-center bg-primary-500 hover:bg-primary-400 text-white font-bold px-8 py-4 rounded-xl transition-colors">
          Go Home
        </a>
        <a href="/#services" class="inline-flex items-center justify-center bg-white/5 hover:bg-white/10 text-white font-semibold px-8 py-4 rounded-xl border border-white/10 transition-colors">
          View Services
        </a>
        <a href="/contact/" class="inline-flex items-center justify-center bg-white/5 hover:bg-white/10 text-white font-semibold px-8 py-4 rounded-xl border border-white/10 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
