---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import JobberForm from '../components/JobberForm.astro';
import { company } from '../data/company';

const pageTitle = "Contact TreeShop LLC | Schedule a Land Assessment | Central Florida";
const pageDesc = `Contact TreeShop LLC for outcome-based land management across Central Florida. Call ${company.phone} or submit a request online. Free on-site assessments.`;
---

<Layout title={pageTitle} description={pageDesc} ogImage="/og-services.webp">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://treeshop.app/" },
      { "@type": "ListItem", "position": 2, "name": "Contact" }
    ]
  })} />

  <Nav mode="subpage" ctaHref="#contact" />

  <section class="pt-20 bg-dark-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-sm text-gray-500 pt-8 sm:pt-12 mb-8">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-gray-300">Contact</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start pb-16 sm:pb-24" id="contact">
        <!-- Left: Contact info -->
        <div>
          <h1 class="text-4xl sm:text-5xl font-black text-white leading-[1.1] mb-6">
            Schedule a Land Assessment Consultation
          </h1>
          <p class="text-lg text-gray-400 mb-8">
            Fill out the form and we'll get back to you within 24 hours. Every project starts with a free on-site assessment — we walk your property, evaluate conditions, and deliver a clear scope and estimate.
          </p>

          <div class="space-y-4 mb-10">
            <a href={company.phoneHref} class="flex items-center gap-4 group">
              <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center group-hover:bg-primary-500/20 transition-colors">
                <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              </div>
              <div>
                <p class="text-white font-semibold group-hover:text-primary-400 transition-colors">{company.phone}</p>
                <p class="text-sm text-gray-400">Call or text anytime</p>
              </div>
            </a>
            <a href={`mailto:${company.email}`} class="flex items-center gap-4 group">
              <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center group-hover:bg-primary-500/20 transition-colors">
                <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              </div>
              <div>
                <p class="text-white font-semibold group-hover:text-primary-400 transition-colors">{company.email}</p>
                <p class="text-sm text-gray-400">Email us directly</p>
              </div>
            </a>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-primary-500/10 rounded-xl flex items-center justify-center">
                <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              </div>
              <div>
                <p class="text-white font-semibold">{company.address.city}, {company.address.state} {company.address.zip}</p>
                <p class="text-sm text-gray-400">Serving {company.stats.counties} counties across Central FL</p>
              </div>
            </div>
          </div>

          <!-- What to expect -->
          <div class="bg-dark-800 border border-white/5 rounded-2xl p-6">
            <h3 class="font-bold text-white mb-4">What to Expect</h3>
            <ol class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-primary-400 font-bold text-sm mt-0.5">1.</span>
                <span class="text-gray-400 text-sm">We respond within 24 hours to schedule your free on-site assessment.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-primary-400 font-bold text-sm mt-0.5">2.</span>
                <span class="text-gray-400 text-sm">Jeremiah walks your property to evaluate terrain, vegetation, and access.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-primary-400 font-bold text-sm mt-0.5">3.</span>
                <span class="text-gray-400 text-sm">You receive a clear scope, timeline, and estimate — no surprises.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-primary-400 font-bold text-sm mt-0.5">4.</span>
                <span class="text-gray-400 text-sm">Once approved, we schedule production and deliver results.</span>
              </li>
            </ol>
          </div>

          <!-- Business hours -->
          <div class="mt-6 bg-dark-800 border border-white/5 rounded-2xl p-6">
            <h3 class="font-bold text-white mb-3">Business Hours</h3>
            <div class="space-y-2">
              <div class="flex justify-between text-sm">
                <span class="text-gray-400">Monday - Saturday</span>
                <span class="text-white">{company.hours.opens} AM - {company.hours.closes.replace(':00', '')} PM</span>
              </div>
              <div class="flex justify-between text-sm">
                <span class="text-gray-400">Sunday</span>
                <span class="text-gray-500">Closed</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Jobber Form -->
        <JobberForm title="Schedule a Land Assessment" subtitle="Tell us about your property and goals." />
      </div>
    </div>
  </section>

  <Footer padBottom={true} />

  <MobileCTA />
</Layout>
