              <p class="text-gray-400 text-sm leading-relaxed">{county.terrain}</p>
            </div>
            <div class="bg-dark-700 border border-white/5 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-white mb-2">Common Projects</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{county.projectTypes}</p>
            </div>
          </div>

          <!-- Environmental & Permits -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-dark-700 border border-white/5 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-white mb-2">Environmental Notes</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{county.environmental}</p>
            </div>
            <div class="bg-dark-700 border border-white/5 rounded-xl p-4">
              <h3 class="text-sm font-semibold text-white mb-2">Permitting</h3>
              <p class="text-gray-400 text-sm leading-relaxed">{county.permits}</p>
            </div>
          </div>

          <!-- Services links -->
          <div>
            <h3 class="text-sm font-semibold text-gray-400 uppercase tracking-widest mb-3">Services in {county.name} County</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {countyServices.map((svc) => (
                <a href={`/areas/${county.slug}/${svc.slug}/`} class="flex items-center justify-between bg-dark-700 border border-white/5 rounded-xl px-4 py-3 hover:border-primary-500/30 transition-colors group">
                  <div>
                    <p class="text-white text-sm font-medium group-hover:text-primary-400 transition-colors">{svc.name}</p>
                  </div>
                  <svg class="w-4 h-4 text-gray-400 group-hover:text-primary-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-3 pt-4 border-t border-white/5">
            <a href="#contact" class="inline-flex items-center justify-center bg-primary-500 hover:bg-primary-600 text-white font-bold px-6 py-3 rounded-xl transition-colors flex-1" onclick={`document.getElementById('county-${county.slug}').close()`}>
              Start Project in {county.name}
            </a>
            <a href="tel:+13868435266" class="inline-flex items-center justify-center bg-white/5 hover:bg-white/10 text-white font-semibold px-6 py-3 rounded-xl border border-white/10 transition-colors flex-1">
              Call (386) 843-5266
            </a>
          </div>
        </div>
      </div>
    </dialog>
  ))}

  <!-- County modal script -->
  <script>
    document.querySelectorAll('[data-county]').forEach(btn => {
      btn.addEventListener('click', () => {
        const slug = btn.getAttribute('data-county');
        document.getElementById(`county-${slug}`)?.showModal();
      });
    });
    document.querySelectorAll('[data-close-county]').forEach(btn => {
      btn.addEventListener('click', () => {
        const slug = btn.getAttribute('data-close-county');
        document.getElementById(`county-${slug}`)?.close();
      });
    });
    document.querySelectorAll('dialog[id^="county-"]').forEach(d => {
      d.addEventListener('click', (e) => {
        if (e.target === d) d.close();
      });
    });
  </script>

  <!-- ============ CTA / CONTACT ============ -->
  <ContactSection heading="Schedule a Land Assessment Consultation" />

  </main>

  <!-- ============ FOOTER ============ -->
  <Footer padBottom={true} />

  <!-- ============ MOBILE STICKY CTA ============ -->
  <MobileCTA ctaLabel="Schedule Assessment" />
</Layout>
