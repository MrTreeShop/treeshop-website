import { counties as countyList, services as countyServices } from '../data/index';
---

<Layout>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Organization"],
    "name": "TreeShop LLC",
    "legalName": "TreeShop LLC",
    "description": "Outcome-based land management across Central Florida. Land clearing, conservation forestry, and wildlife habitat restoration. 10+ years experience, 500+ projects completed.",
    "url": "https://treeshop.app",
    "telephone": "+13868435266",
    "email": "office@treeshop.app",
    "logo": "https://treeshop.app/favicon.png",
    "image": "https://treeshop.app/og-image.jpg",
    "foundingDate": "2016",
    "founder": [
      { "@type": "Person", "name": "Jeremiah Anderson" },
      { "@type": "Person", "name": "Lacey Anderson" }
    ],
    "numberOfEmployees": { "@type": "QuantitativeValue", "value": 2 },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "New Smyrna Beach",
      "addressLocality": "New Smyrna Beach",
      "addressRegion": "FL",
      "postalCode": "32168",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 29.0280,
      "longitude": -81.0649
    },
    "areaServed": {
      "@type": "State",
      "name": "Florida"
    },
    "priceRange": "$$",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "97",
      "bestRating": "5"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "07:00",
      "closes": "16:00"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Land Management Services",
      "itemListElement": services.map(s => ({
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": s.name,
          "description": s.desc
        }
      }))
    },
    "knowsAbout": [
      "Forestry Mulching",
      "Land Clearing",
      "Wildlife Habitat Restoration",
      "Prescribed Fire Preparation",
      "Timber Stand Improvement",
      "Invasive Species Management",
