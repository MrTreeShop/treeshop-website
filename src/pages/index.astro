---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.png';
---

<Layout>
  <main class="flex min-h-screen flex-col items-center justify-center bg-[#0a0a0a] px-6 text-center">
    <Image
      src={logo}
      alt="TreeShop LLC"
      width={180}
      height={180}
      class="mb-10 h-auto w-32 sm:w-40"
    />
    <h1 class="text-4xl font-semibold italic tracking-tight text-white sm:text-6xl">
      Veni, vidi, vici
    </h1>
    <p class="mt-4 text-lg text-neutral-400 sm:text-xl">
      Jeremiah
    </p>
  </main>
</Layout>
