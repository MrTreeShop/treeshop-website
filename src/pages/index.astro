  <!-- Services spotlight script -->
  <script>
    function initServiceSpotlight() {
      const tabs = document.querySelectorAll('[data-svc-tab]');
      const panels = document.querySelectorAll('.svc-panel');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const id = tab.getAttribute('data-svc-tab');

          // Hide all panels
          panels.forEach(p => p.classList.add('hidden'));

          // Show selected panel
          const target = document.getElementById(`svc-panel-${id}`);
          if (target) {
            target.classList.remove('hidden');
            target.style.animation = 'none';
            target.offsetHeight; // trigger reflow
            target.style.animation = 'svcFadeIn 0.25s ease-out';
          }

          // Update all tabs (both mobile and desktop)
          tabs.forEach(t => {
            const isActive = t.getAttribute('data-svc-tab') === id;
            // Desktop sidebar tabs
            if (t.classList.contains('svc-tab')) {
              if (isActive) {
                t.classList.add('bg-primary-500/10');
                t.classList.remove('hover:bg-white/5');
                t.style.borderColor = 'rgba(13,139,240,0.3)';
                t.querySelector('p')!.classList.add('text-primary-400');
                t.querySelector('p')!.classList.remove('text-gray-300');
                t.querySelector('p:last-child')!.classList.add('text-primary-400/70');
                t.querySelector('p:last-child')!.classList.remove('text-gray-500');
                t.querySelector('svg')!.classList.add('text-primary-400');
                t.querySelector('svg')!.classList.remove('text-gray-600');
              } else {
                t.classList.remove('bg-primary-500/10');
                t.classList.add('hover:bg-white/5');
                t.style.borderColor = 'transparent';
                t.querySelector('p')!.classList.remove('text-primary-400');
                t.querySelector('p')!.classList.add('text-gray-300');
                t.querySelector('p:last-child')!.classList.remove('text-primary-400/70');
                t.querySelector('p:last-child')!.classList.add('text-gray-500');
                t.querySelector('svg')!.classList.remove('text-primary-400');
                t.querySelector('svg')!.classList.add('text-gray-600');
              }
            } else {
              // Mobile pill tabs
              if (isActive) {
                t.classList.add('bg-primary-500/10', 'border-primary-500/30', 'text-primary-400');
                t.classList.remove('bg-dark-800', 'border-white/5', 'text-gray-400');
              } else {
                t.classList.remove('bg-primary-500/10', 'border-primary-500/30', 'text-primary-400');
                t.classList.add('bg-dark-800', 'border-white/5', 'text-gray-400');
              }
            }
          });
        });
      });
    }
    initServiceSpotlight();
  </script>

